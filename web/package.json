{
  "name": "libre-web",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "description": "Build tooling for libre. At runtime the app is static files only; the sole build step vendors nostr-tools into vendor/nostr-tools.js.",
  "type": "module",
  "scripts": {
    "build:vendor": "esbuild vendor-entry.js --bundle --format=esm --minify --outfile=vendor/nostr-tools.js",
    "build": "node build.js",
    "test": "node --test src/**/*.test.js"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "nostr-tools": "^2.10.4",
    "terser": "^5.48.0"
  }
}
